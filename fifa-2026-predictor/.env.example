# Copy this file to .env and fill in real values.
# Never commit .env — it is listed in .gitignore.

# football-data.org API key (required for /refresh live match data)
FOOTBALL_DATA_API_KEY=your_key_here

# Comma-separated list of allowed CORS origins
# Development default: http://localhost:3000,http://localhost:3001
# Production: set to your Vercel frontend URL
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:3001

# Secret token required to call POST /refresh in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
REFRESH_SECRET=

# Set to "production" on Railway to enable production guards
# (disables /docs, /redoc; enforces REFRESH_SECRET; stricter CORS)
ENV=development
