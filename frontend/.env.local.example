# Copy this file to .env.local for local development.
# In production, set this as an environment variable in Vercel.
# .env.local is listed in .gitignore — never commit it.

# Backend API base URL (no trailing slash)
# Development: leave empty to use the http://127.0.0.1:8000/api/v1 default
# Production: set to your Railway backend URL
NEXT_PUBLIC_API_BASE_URL=https://<your-railway-app>.up.railway.app/api/v1
